# --- Core ---
ENV=development
DATABASE_URL=sqlite:///./support_agents.db

# Optional auth. API_TOKEN gates the whole API (single-tenant mode).
# ADMIN_TOKEN enables POST /api/v1/admin/tenants (per-tenant API keys).
API_TOKEN=
ADMIN_TOKEN=

# --- Groq (remote LLM, optional - free tier) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Ollama (local fallback, optional) ---
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Mock provider (final safety net; keep true for local/no-LLM runs) ---
MOCK_ENABLED=true

# --- Voice ---
# TTS: Kokoro runs on CPU (zero VRAM). Engine "chatterbox" tries the cloning
# micro-service on :8002 first and falls back to Kokoro automatically.
TTS_ENABLED=true
TTS_ENGINE=kokoro
TTS_VOICE=ef_dora
TTS_LANG=es
CHATTERBOX_URL=http://127.0.0.1:8002
CHATTERBOX_VOICE=
# STT uses GROQ_API_KEY (whisper-large-v3-turbo)
STT_LANGUAGE=es

# --- Local embeddings for knowledge retrieval (requires Ollama) ---
EMBEDDINGS_ENABLED=true
EMBEDDING_MODEL=nomic-embed-text
KNOWLEDGE_MIN_SIMILARITY=0.55

# --- Workflow policies ---
QUALITY_THRESHOLD=0.5
CONFIDENCE_THRESHOLD=0.4
MAX_QUALITY_RETRIES=1
KNOWLEDGE_TOP_K=3
LLM_TIMEOUT_SECONDS=30
